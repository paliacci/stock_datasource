{
  "table_name": "ods_hk_adjfactor",
  "columns": [
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "Date"
    },
    {
      "name": "cum_adjfactor",
      "comment": "累计复权因子",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "close_price",
      "comment": "收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "version",
      "default": "toUInt32(toUnixTimestamp(now()))",
      "comment": "版本号",
      "data_type": "UInt32"
    },
    {
      "name": "_ingested_at",
      "default": "now()",
      "comment": "入库时间",
      "data_type": "DateTime"
    }
  ],
  "engine": "ReplacingMergeTree(version)",
  "partition_by": "toYYYYMM(trade_date)",
  "order_by": [
    "ts_code",
    "trade_date"
  ],
  "comment": "港股复权因子 from TuShare hk_adjfactor API"
}