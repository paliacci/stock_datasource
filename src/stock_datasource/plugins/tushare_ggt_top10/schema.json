{
  "table_name": "ods_ggt_top10",
  "database": "stock_datasource",
  "engine": "ReplacingMergeTree()",
  "partition_by": "substring(trade_date, 1, 6)",
  "order_by": [
    "ts_code",
    "trade_date",
    "market_type"
  ],
  "comment": "港股通每日十大成交股数据",
  "columns": [
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "String"
    },
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "String"
    },
    {
      "name": "name",
      "comment": "股票名称",
      "data_type": "Nullable(String)"
    },
    {
      "name": "close",
      "comment": "收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "p_change",
      "comment": "涨跌幅",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "rank",
      "comment": "资金排名",
      "data_type": "Int32 DEFAULT 0"
    },
    {
      "name": "market_type",
      "comment": "市场类型：2-港股通(沪)，4-港股通(深)",
      "data_type": "String"
    },
    {
      "name": "amount",
      "comment": "累计成交金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "net_amount",
      "comment": "净买入金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sh_amount",
      "comment": "沪市成交金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sh_net_amount",
      "comment": "沪市净买入金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sh_buy",
      "comment": "沪市买入金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sh_sell",
      "comment": "沪市卖出金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sz_amount",
      "comment": "深市成交金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sz_net_amount",
      "comment": "深市净买入金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sz_buy",
      "comment": "深市买入金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sz_sell",
      "comment": "深市卖出金额(元)",
      "data_type": "Nullable(Float64)"
    }
  ]
}