{
  "table_name": "ods_min_kline_index",
  "engine": "ReplacingMergeTree(version)",
  "partition_by": "toYYYYMM(trade_time)",
  "order_by": [
    "ts_code",
    "freq",
    "trade_time"
  ],
  "comment": "指数分钟K线行情数据",
  "columns": [
    {
      "name": "ts_code",
      "comment": "指数代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "freq",
      "comment": "分钟频度(1min/5min/15min/30min/60min)",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "trade_time",
      "comment": "交易时间",
      "data_type": "DateTime"
    },
    {
      "name": "open",
      "comment": "开盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "close",
      "comment": "收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "high",
      "comment": "最高价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "low",
      "comment": "最低价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "vol",
      "comment": "成交量(股)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "amount",
      "comment": "成交金额(元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "version",
      "default": "toUInt32(toUnixTimestamp(now()))",
      "comment": "版本号用于幂等",
      "data_type": "UInt32"
    },
    {
      "name": "_ingested_at",
      "default": "now()",
      "comment": "数据入库时间",
      "data_type": "DateTime"
    }
  ]
}