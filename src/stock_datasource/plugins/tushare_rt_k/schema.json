{
  "table_name": "ods_rt_k",
  "engine": "ReplacingMergeTree(version)",
  "partition_by": "toYYYYMMDD(trade_time)",
  "order_by": [
    "ts_code",
    "trade_time"
  ],
  "comment": "沪深京实时日线 from TuShare rt_k API",
  "columns": [
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "name",
      "comment": "股票名称",
      "data_type": "String"
    },
    {
      "name": "pre_close",
      "comment": "昨收价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "high",
      "comment": "最高价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "open",
      "comment": "开盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "low",
      "comment": "最低价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "close",
      "comment": "收盘价(最新价)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "vol",
      "comment": "成交量(股)",
      "data_type": "Nullable(Int64)"
    },
    {
      "name": "amount",
      "comment": "成交金额(元)",
      "data_type": "Nullable(Int64)"
    },
    {
      "name": "num",
      "comment": "成交笔数",
      "data_type": "Nullable(Int32)"
    },
    {
      "name": "ask_price1",
      "comment": "委托卖一价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "ask_volume1",
      "comment": "委托卖一量",
      "data_type": "Nullable(Int64)"
    },
    {
      "name": "bid_price1",
      "comment": "委托买一价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "bid_volume1",
      "comment": "委托买一量",
      "data_type": "Nullable(Int64)"
    },
    {
      "name": "trade_time",
      "comment": "交易时间",
      "data_type": "DateTime"
    },
    {
      "name": "version",
      "default": "toUInt32(toUnixTimestamp(now()))",
      "comment": "版本号用于幂等",
      "data_type": "UInt32"
    },
    {
      "name": "_ingested_at",
      "default": "now()",
      "comment": "数据入库时间",
      "data_type": "DateTime"
    }
  ]
}