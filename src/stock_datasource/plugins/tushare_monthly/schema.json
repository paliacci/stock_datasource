{
  "table_name": "ods_monthly",
  "database": "stock_datasource",
  "columns": [
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "String"
    },
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "String"
    },
    {
      "name": "open",
      "comment": "月开盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "high",
      "comment": "月最高价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "low",
      "comment": "月最低价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "close",
      "comment": "月收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "pre_close",
      "comment": "上月收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "change",
      "comment": "月涨跌额",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "pct_chg",
      "comment": "月涨跌幅",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "vol",
      "comment": "月成交量",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "amount",
      "comment": "月成交额",
      "data_type": "Nullable(Float64)"
    }
  ],
  "engine": "ReplacingMergeTree()",
  "partition_by": "substring(trade_date, 1, 4)",
  "order_by": [
    "ts_code",
    "trade_date"
  ],
  "comment": "A股月线行情数据"
}