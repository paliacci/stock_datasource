{
  "table_name": "ods_hk_daily_adj",
  "columns": [
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "Date"
    },
    {
      "name": "open",
      "comment": "开盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "high",
      "comment": "最高价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "low",
      "comment": "最低价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "close",
      "comment": "收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "pre_close",
      "comment": "昨收价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "change",
      "comment": "涨跌额",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "pct_change",
      "comment": "涨跌幅",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "vol",
      "comment": "成交量",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "amount",
      "comment": "成交额",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "vwap",
      "comment": "平均价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "adj_factor",
      "comment": "复权因子",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "turnover_ratio",
      "comment": "换手率(基于总股本)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "free_share",
      "comment": "流通股本",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_share",
      "comment": "总股本",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "free_mv",
      "comment": "流通市值",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_mv",
      "comment": "总市值",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "version",
      "default": "toUInt32(toUnixTimestamp(now()))",
      "comment": "版本号",
      "data_type": "UInt32"
    },
    {
      "name": "_ingested_at",
      "default": "now()",
      "comment": "入库时间",
      "data_type": "DateTime"
    }
  ],
  "engine": "ReplacingMergeTree(version)",
  "partition_by": "toYYYYMM(trade_date)",
  "order_by": [
    "ts_code",
    "trade_date"
  ],
  "comment": "港股复权行情 from TuShare hk_daily_adj API"
}