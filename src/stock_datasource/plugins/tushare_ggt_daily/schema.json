{
  "table_name": "ods_ggt_daily",
  "database": "stock_datasource",
  "engine": "ReplacingMergeTree()",
  "partition_by": "substring(trade_date, 1, 4)",
  "order_by": [
    "trade_date"
  ],
  "comment": "港股通每日成交统计数据",
  "columns": [
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "String"
    },
    {
      "name": "buy_amount",
      "comment": "买入成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "buy_volume",
      "comment": "买入成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sell_amount",
      "comment": "卖出成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sell_volume",
      "comment": "卖出成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    }
  ]
}