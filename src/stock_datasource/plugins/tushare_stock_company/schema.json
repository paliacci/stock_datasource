{
  "table_name": "ods_stock_company",
  "engine": "ReplacingMergeTree(version)",
  "partition_by": null,
  "order_by": [
    "ts_code"
  ],
  "comment": "上市公司基础信息 from TuShare stock_company API",
  "columns": [
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "com_name",
      "comment": "公司全称",
      "data_type": "String"
    },
    {
      "name": "com_id",
      "comment": "统一社会信用代码",
      "data_type": "String"
    },
    {
      "name": "exchange",
      "comment": "交易所代码",
      "data_type": "LowCardinality(String)"
    },
    {
      "name": "chairman",
      "comment": "法人代表",
      "data_type": "String"
    },
    {
      "name": "manager",
      "comment": "总经理",
      "data_type": "String"
    },
    {
      "name": "secretary",
      "comment": "董秘",
      "data_type": "String"
    },
    {
      "name": "reg_capital",
      "comment": "注册资本(万元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "setup_date",
      "comment": "注册日期",
      "data_type": "Nullable(Date)"
    },
    {
      "name": "province",
      "comment": "所在省份",
      "data_type": "String"
    },
    {
      "name": "city",
      "comment": "所在城市",
      "data_type": "String"
    },
    {
      "name": "introduction",
      "comment": "公司介绍",
      "data_type": "String"
    },
    {
      "name": "website",
      "comment": "公司主页",
      "data_type": "String"
    },
    {
      "name": "email",
      "comment": "电子邮件",
      "data_type": "String"
    },
    {
      "name": "office",
      "comment": "办公室地址",
      "data_type": "String"
    },
    {
      "name": "employees",
      "comment": "员工人数",
      "data_type": "Nullable(Int32)"
    },
    {
      "name": "main_business",
      "comment": "主要业务及产品",
      "data_type": "String"
    },
    {
      "name": "business_scope",
      "comment": "经营范围",
      "data_type": "String"
    },
    {
      "name": "version",
      "default": "toUInt32(toUnixTimestamp(now()))",
      "comment": "版本号用于幂等",
      "data_type": "UInt32"
    },
    {
      "name": "_ingested_at",
      "default": "now()",
      "comment": "数据入库时间",
      "data_type": "DateTime"
    }
  ]
}