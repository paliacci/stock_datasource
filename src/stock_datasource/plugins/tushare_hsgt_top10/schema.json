{
  "table_name": "ods_hsgt_top10",
  "database": "stock_datasource",
  "columns": [
    {
      "name": "trade_date",
      "comment": "交易日期",
      "data_type": "String"
    },
    {
      "name": "ts_code",
      "comment": "股票代码",
      "data_type": "String"
    },
    {
      "name": "name",
      "comment": "股票名称",
      "data_type": "Nullable(String)"
    },
    {
      "name": "close",
      "comment": "收盘价",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "change",
      "comment": "涨跌额",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "rank",
      "comment": "资金排名",
      "data_type": "Int32 DEFAULT 0"
    },
    {
      "name": "market_type",
      "comment": "市场类型：1-沪市，3-深市",
      "data_type": "String"
    },
    {
      "name": "amount",
      "comment": "成交金额（元）",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "net_amount",
      "comment": "净成交金额（元）",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "buy",
      "comment": "买入金额（元）",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "sell",
      "comment": "卖出金额（元）",
      "data_type": "Nullable(Float64)"
    }
  ],
  "engine": "ReplacingMergeTree()",
  "partition_by": "substring(trade_date, 1, 6)",
  "order_by": [
    "trade_date",
    "market_type",
    "rank"
  ],
  "comment": "沪深股通每日前十大成交股"
}