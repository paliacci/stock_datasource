{
  "table_name": "ods_ggt_monthly",
  "database": "stock_datasource",
  "engine": "ReplacingMergeTree()",
  "partition_by": "substring(month, 1, 4)",
  "order_by": [
    "month"
  ],
  "comment": "港股通每月成交统计数据",
  "columns": [
    {
      "name": "month",
      "comment": "交易月份",
      "data_type": "String"
    },
    {
      "name": "day_buy_amt",
      "comment": "当月日均买入成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "day_buy_vol",
      "comment": "当月日均买入成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "day_sell_amt",
      "comment": "当月日均卖出成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "day_sell_vol",
      "comment": "当月日均卖出成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_buy_amt",
      "comment": "总买入成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_buy_vol",
      "comment": "总买入成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_sell_amt",
      "comment": "总卖出成交金额(亿元)",
      "data_type": "Nullable(Float64)"
    },
    {
      "name": "total_sell_vol",
      "comment": "总卖出成交笔数(万笔)",
      "data_type": "Nullable(Float64)"
    }
  ]
}